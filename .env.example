# ---- Backend (FastAPI) ----
ENVIRONMENT=development
FRONTEND_ORIGIN=http://localhost:5173
DATABASE_URL=sqlite:///./data/fasalbima.db

# ---- Speech-to-text (Feature 2: Voice Assistance via Groq Whisper) ----
GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3
SPEECH_DEFAULT_LANGUAGE=kn
SPEECH_MAX_AUDIO_SIZE_MB=15
SPEECH_REQUEST_TIMEOUT_SECONDS=25.0

# ---- External APIs (used starting Module 8) ----
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# ---- Image classification (Feature 5: MobileNetV2) ----
CLASSIFIER_CHECKPOINT_PATH=../ml/outputs/checkpoints/best_model.pth
CLASSIFIER_CLASS_NAMES_PATH=../ml/outputs/checkpoints/class_names.json
CLASSIFIER_MAX_IMAGE_SIZE_MB=10

# ---- Frontend (Vite) ----
# Vite only exposes variables prefixed with VITE_ to the browser bundle.
# Not needed yet in Module 1 — the dev server proxy handles routing to the
# backend — but declared here so the pattern is established from the start.
VITE_API_BASE_URL=/api
